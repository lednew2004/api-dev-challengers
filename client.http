@baseurl = http://localhost:3333

### Create user
POST {{baseurl}}/users
Content-Type: application/json

{
    "name": "john doe",
    "email": "johndoe@example.com",
    "password": "123456"
}

### authenticate user
POST {{baseurl}}/session
Content-Type: application/json

{
    "email": "wendellkauan870@gmail.com",
    "password": "wendelkaua@2004"
}

